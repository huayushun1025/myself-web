---
import ParticleBackground from './ParticleBackground.tsx';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Dynamic Particle Background -->
  <ParticleBackground client:load />

  <!-- Gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute -top-[30%] -left-[10%] w-[700px] h-[700px] rounded-full opacity-30 blur-[150px]"
      style="background: radial-gradient(circle, hsl(270 70% 60%) 0%, transparent 70%);"
    ></div>
    <div
      class="absolute -bottom-[20%] -right-[10%] w-[500px] h-[500px] rounded-full opacity-20 blur-[120px]"
      style="background: radial-gradient(circle, hsl(190 70% 60%) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Hero Title -->
    <div class="mb-12">
      <h1 class="text-5xl sm:text-6xl lg:text-8xl font-bold tracking-[0.15em] mb-6 leading-tight" style="color: hsl(270 70% 65%);">
        <span class="gradient-text">欢迎来到</span>
      </h1>
      <h1 class="text-6xl sm:text-7xl lg:text-9xl font-bold tracking-tight mb-6 flower-animate">
        flower
      </h1>
      <h1 class="text-5xl sm:text-6xl lg:text-8xl font-bold tracking-[0.15em] gradient-text">
        的空间
      </h1>

      <!-- Decoration line -->
      <div class="flex items-center justify-center gap-4 mt-6">
        <span class="w-12 h-px bg-gradient-to-r from-transparent to-purple-500/50"></span>
        <span class="text-sm text-gray-400 tracking-[0.3em] uppercase">Welcome to My World</span>
        <span class="w-12 h-px bg-gradient-to-l from-transparent to-purple-500/50"></span>
      </div>
    </div>

    <!-- Online status badge -->
    <div class="mb-8">
      <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-purple-500/10 border border-purple-500/30 text-sm text-purple-400 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-purple-400"></span>
        </span>
        你好，欢迎来到我的技术世界
      </span>
    </div>

    <!-- Typewriter subtitle -->
    <div class="h-12 sm:h-14 flex items-center justify-center mb-8">
      <div class="text-xl sm:text-2xl lg:text-3xl font-medium">
        <span id="typewriter-text" class="gradient-text"></span>
        <span class="cursor-blink border-r-2 border-purple-400 ml-1">&nbsp;</span>
      </div>
    </div>

    <!-- Description -->
    <p class="text-base sm:text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed mb-10">
      专注于 AIGC 工具、Agent 开发、AI 前沿技术分享。
      <br class="hidden sm:block" />
      在这里分享技术见解、项目经验和工程实践。
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col items-center justify-center gap-3 sm:gap-4">
      <!-- Buttons Row - Always horizontal -->
      <div class="flex flex-row items-center justify-center gap-2 sm:gap-4 px-2 sm:px-0">
        <a
          href="/blog"
          class="group relative px-4 sm:px-6 py-2.5 sm:py-3 rounded-lg sm:rounded-xl font-semibold text-white transition-all duration-300 hover:scale-105 overflow-hidden text-xs sm:text-sm"
          style="background: linear-gradient(135deg, hsl(270 70% 60%), hsl(190 70% 60%)); box-shadow: 0 4px 20px -4px hsl(270 70% 60% / 0.5);"
        >
          <span class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-gradient-to-r from-transparent via-white/30 to-transparent"></span>
          <span class="relative z-10 flex items-center justify-center gap-1.5 sm:gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            阅读博客
          </span>
        </a>

        <a
          href="/projects"
          class="group px-4 sm:px-6 py-2.5 sm:py-3 rounded-lg sm:rounded-xl font-semibold border-2 border-purple-500/30 bg-white/5 backdrop-blur-sm hover:bg-white/10 hover:border-purple-500/50 transition-all duration-300 hover:scale-105 flex items-center justify-center gap-1.5 sm:gap-2 text-xs sm:text-sm"
        >
          <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          查看项目
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="flex flex-col items-center gap-1 text-gray-500 animate-bounce">
        <span class="text-[10px] sm:text-xs tracking-widest uppercase">向下滚动</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  // Typewriter effect
  const texts = [
    'AIGC工程师',
    'LLM 爱好者',
    '技术博客作者',
    '开源贡献者',
  ];

  const typewriterElement = document.getElementById('typewriter-text');
  if (typewriterElement) {
    let textIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    let typeSpeed = 100;

    const type = () => {
      const currentText = texts[textIndex];

      if (isDeleting) {
        typewriterElement.textContent = currentText.substring(0, charIndex - 1);
        charIndex--;
        typeSpeed = 50;
      } else {
        typewriterElement.textContent = currentText.substring(0, charIndex + 1);
        charIndex++;
        typeSpeed = 100;
      }

      if (!isDeleting && charIndex === currentText.length) {
        typeSpeed = 2000;
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        textIndex = (textIndex + 1) % texts.length;
        typeSpeed = 500;
      }

      setTimeout(type, typeSpeed);
    };

    setTimeout(type, 1000);
  }
</script>

<style>
  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, hsl(270 70% 65%), hsl(190 70% 65%));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Flower special animation */
  .flower-animate {
    background: linear-gradient(
      90deg,
      hsl(280 70% 60%) 0%,
      hsl(320 70% 60%) 25%,
      hsl(190 70% 60%) 50%,
      hsl(280 70% 60%) 75%,
      hsl(320 70% 60%) 100%
    );
    background-size: 300% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: rainbow-flow 4s ease infinite, float-up 3s ease-in-out infinite;
    font-weight: 800;
    text-shadow:
      0 0 30px hsl(280 70% 60% / 0.6),
      0 0 60px hsl(320 70% 60% / 0.4);
  }

  @keyframes rainbow-flow {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 300% center;
    }
  }

  @keyframes float-up {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-10px) scale(1.02);
    }
  }

  @keyframes blink {
    0%, 100% {
      border-color: hsl(270 70% 60%);
    }
    50% {
      border-color: transparent;
    }
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
</style>
