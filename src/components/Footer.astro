---
const currentYear = new Date().getFullYear();

const socialLinks = [
  {
    name: 'GitHub',
    href: 'https://github.com/huayushun1025',
    icon: 'github',
  },
  {
    name: 'Twitter',
    href: 'https://twitter.com',
    icon: 'twitter',
  },
  {
    name: 'Email',
    href: 'mailto:hys1025@outlook.com',
    icon: 'mail',
  },
];
---

<footer class="border-t border-border/30 bg-card/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="text-xl font-bold gradient-text">
          flower
        </a>
        <p class="text-sm text-muted-foreground">
          AIGC工程师 & 技术探索者<br />
          专注于 AIGC、大语言模型和全栈开发
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold mb-4">快速链接</h3>
        <ul class="space-y-2">
          <li>
            <a href="/" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
              首页
            </a>
          </li>
          <li>
            <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
              技术博客
            </a>
          </li>
          <li>
            <a href="/projects" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
              产品项目
            </a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-sm font-semibold mb-4">联系方式</h3>
        <div class="flex space-x-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg bg-accent/50 hover:bg-accent transition-colors"
              aria-label={link.name}
            >
              {link.icon === 'github' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    fill-rule="evenodd"
                    d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                    clip-rule="evenodd"
                  />
                </svg>
              )}
              {link.icon === 'twitter' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              )}
              {link.icon === 'mail' && (
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-8 pt-8 border-t border-border/30 text-center">
      <p class="text-sm text-muted-foreground">
        &copy; {currentYear} Dev. All rights reserved. Built with Astro.
      </p>
    </div>
  </div>
</footer>
