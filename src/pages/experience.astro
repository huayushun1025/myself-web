---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Timeline from '@/components/Timeline.astro';

const experiences = [
  {
    title: '技术支持工程师',
    company: '杭州顺网科技股份有限公司',
    period: '2023.12 - 2025.10',
    description: '日处理技术工单100+，分类分级闭环处理，客诉满意度高。与产品/研发团队协作复现问题定位根因推动修复。从0到1参与AI客服系统部署，负责知识库搭建和流程配置。设计客服对话流程和意图识别规则，实现问答自动回复。开发工单系统API接口同步客户信息。持续优化知识库和Prompt，问答准确率从75%提升至92%。培训客服团队使用AI系统，编写操作手册。',
    tags: ['AI客服', '知识库', '工单系统', 'LangChain', 'Python'],
  },
  {
    title: 'IT专员',
    company: '浙江富春集团杭加新材料有限公司',
    period: '2022.10 - 2023.03',
    description: '独立设计企业级工作流流程，完成OA审批流程搭建，实现线下转线上流程。主导CRM-OA系统集成项目，负责接口设计、字段映射、测试，保障系统数据流稳定。处理日常IT请求50+，跨部门沟通协调能力强，项目上线满意度高。',
    tags: ['OA系统', 'CRM', '工作流', '系统集成'],
  },
];

const education = [
  {
    title: '信息管理与信息系统 · 学士',
    company: '北方民族大学',
    period: '2018 - 2022',
    description: '主修课程包括C语言、Java、数据结构、操作系统、计算机网络、会计学、经济学等。毕业设计《基于树莓派的物联网数据采集系统》获得优秀毕业论文。',
    tags: ['C语言', 'Java', '数据结构', '操作系统', '计算机网络'],
  },
];
---

<BaseLayout
  title="个人经历 | flower"
  description="职业经历 - 从初入职场到技术专家的成长之路"
>
  <div class="pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">
          <span class="gradient-text">个人经历</span>
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          从初入职场到技术专家的成长之路，记录每一个重要节点和突破时刻。
        </p>
      </div>

      <!-- Work Experience -->
      <section class="mb-20">
        <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
          <span class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </span>
          工作经历
        </h2>
        <Timeline items={experiences} />
      </section>

      <!-- Education -->
      <section>
        <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
          <span class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
            </svg>
          </span>
          教育背景
        </h2>
        <Timeline items={education} />
      </section>

      <!-- Skills Summary -->
      <section class="mt-20">
        <h2 class="text-2xl font-bold mb-8 text-center">
          <span class="gradient-text">技术能力</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            {
              category: '前端开发',
              items: ['React / Next.js', 'Vue / Nuxt', 'TypeScript', 'Tailwind CSS'],
              level: 90,
            },
            {
              category: '后端开发',
              items: ['Node.js', 'Python / FastAPI', 'Go', 'RESTful API'],
              level: 85,
            },
            {
              category: '物联网',
              items: ['ESP32 / Arduino', 'MQTT / CoAP', 'Node-RED', 'Home Assistant'],
              level: 88,
            },
            {
              category: 'AI / ML',
              items: ['LangChain', 'Ollama', 'PyTorch', 'RAG 应用'],
              level: 75,
            },
          ].map((skill) => (
            <div class="p-6 rounded-xl bg-card border border-border">
              <h3 class="text-lg font-semibold mb-4">{skill.category}</h3>
              <!-- Progress bar -->
              <div class="mb-4">
                <div class="h-2 bg-accent rounded-full overflow-hidden">
                  <div
                    class="h-full rounded-full transition-all duration-1000"
                    style={`width: ${skill.level}%; background: linear-gradient(90deg, hsl(var(--primary)), hsl(190 70% 60%));`}
                  ></div>
                </div>
              </div>
              <!-- Tags -->
              <div class="flex flex-wrap gap-2">
                {skill.items.map((item) => (
                  <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-accent/80 text-accent-foreground">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
